{
  "name": "cds-playground",
  "private": true,
  "workspaces": [
    "web"
  ],
  "scripts": {
    "web:dev": "yarn workspace cds-playground-web dev",
    "web:build": "yarn workspace cds-playground-web build",
    "web:start": "yarn workspace cds-playground-web start",
    "web:lint": "yarn workspace cds-playground-web lint",
    "web:format": "yarn workspace cds-playground-web format",
    "mobile:dev": "cd mobile && npm run dev",
    "mobile:start": "cd mobile && npm start",
    "mobile:android": "cd mobile && npm run android",
    "mobile:ios": "cd mobile && npm run ios",
    "mobile:web": "cd mobile && npm run web",
    "mobile:install": "cd mobile && npm install"
  },
  "engines": {
    "node": "^18.19"
  },
  "packageManager": "yarn@4.0.2"
}
